# ============================================================
# trusty-izzie environment configuration
# Copy this file to .env and fill in the values below.
# Lines starting with # are comments and are ignored at runtime.
# ============================================================

# --- LLM Inference (OpenRouter) ---

# Required: Your OpenRouter API key for LLM inference (chat + entity extraction).
# Obtain at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key

# --- Google OAuth 2.0 ---

# Required: OAuth 2.0 Client ID from Google Cloud Console.
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → Create Credentials → OAuth client ID
# Application type: Desktop app (or Web app with the redirect URI below)
GOOGLE_CLIENT_ID=your_google_client_id

# Required: OAuth 2.0 Client Secret corresponding to the Client ID above.
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- User Identity ---

# Required: The primary Gmail address to sync and use as the owner identity.
TRUSTY_PRIMARY_EMAIL=your@email.com

# --- Telegram Bot (optional) ---

# Optional: Bot token from @BotFather on Telegram.
# Required only if you want to use the Telegram interface (trusty-telegram).
# Create a bot: open Telegram → search @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# --- Search (optional) ---

# Optional: Brave Search API key for web search tool support.
# Obtain at: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# --- Storage ---

# Optional: Directory where all persistent data is stored (vectors, graph, SQLite).
# Default: ~/.local/share/trusty-izzie
# The ~ is expanded at runtime.
TRUSTY_DATA_DIR=~/.local/share/trusty-izzie

# --- Logging ---

# Optional: Log verbosity level. One of: trace, debug, info, warn, error.
# Default: info
TRUSTY_LOG_LEVEL=info

# --- API Server ---

# Optional: Port for the REST API server (trusty-api).
# Default: 3456
TRUSTY_API_PORT=3456

# Optional: Host address to bind the REST API server.
# Default: 127.0.0.1 (loopback only — change to 0.0.0.0 to expose on LAN)
TRUSTY_API_HOST=127.0.0.1

# --- Public Domain (for webhooks and OAuth callbacks) ---

# Optional: Public domain or host:port used to build callback and webhook URLs.
# Required if using Telegram webhooks or OAuth callbacks via a public URL (e.g. ngrok).
# Example: myndomain.ngrok.io
# Example: localhost:3456 (for local-only development)
TRUSTY_NGROK_DOMAIN=your.ngrok.domain

# Optional: Full public base URL (scheme + domain) used in Telegram webhook setup.
# Example: https://myndomain.ngrok.io
TRUSTY_PUBLIC_URL=https://your.ngrok.domain

# --- Google OAuth Redirect URI ---

# Optional: The redirect URI registered in Google Cloud Console for the OAuth flow.
# Must exactly match one of the URIs in your OAuth client's "Authorized redirect URIs".
# Default when TRUSTY_PUBLIC_DOMAIN is unset: http://localhost:3456
GOOGLE_REDIRECT_URI=http://localhost:8080/callback

# --- Metro North Train Schedules (optional) ---

# Optional: MTA API key for real-time Metro North train schedules and alerts.
# Free registration at: https://api.mta.info
# MTA_API_KEY=your_mta_api_key_here
