# =============================================================================
# trusty-izzie — environment configuration template
# =============================================================================
#
# SECRETS (stored in macOS Keychain on first run — do not commit real values):
# Run `security find-generic-password -s trusty-izzie` to inspect stored keys.
#
# On first startup, any of these set in .env are automatically migrated to
# the Keychain via trusty_core::secrets::migrate_from_env(). After migration
# you can remove them from .env.
#
# OPENROUTER_API_KEY=sk-or-v1-...
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_USER_TOKEN=xoxp-...
# SLACK_SIGNING_SECRET=...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# TELEGRAM_BOT_TOKEN=...
# BRAVE_SEARCH_API_KEY=...
# TAVILY_API_KEY=tvly-...
# FIRECRAWL_API_KEY=fc-...
# SKYVERN_API_KEY=eyJ...
# SERPAPI_API_KEY=...

