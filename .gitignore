# Rust build artifacts
/target

# Environment / secrets
.env
.env.local
.env.*.local

# Local databases — never commit (per-instance data)
*.db
*.db-shm
*.db-wal
data/
lance/
kuzu/
tantivy/

# LanceDB directories (.lance files)
**/*.lance/
**/lance/

# Kuzu graph DB
**/kuzu/

# Tantivy full-text index
**/tantivy/

# fastembed ONNX model cache
.fastembed_cache/
models/

# Logs
*.log
logs/

# macOS
.DS_Store

# Migration artifacts (keep scripts, not outputs)
migration/output/
migration/*.jsonl
migration/*.parquet
migration/*.json
migration/migration.log

# MCP Vector Search index directory
.mcp-vector-search/

# KuzuMemory project memories database
.kuzu-memory/

# Claude MPM agent configuration and memories (local session state)
.claude-mpm/

# Claude Code local settings
.claude/

# Research notes — may contain local credentials / PII
docs/research/

# Kuzu memory backups
.kuzu-memory-backups/

# MCP configuration (machine-specific paths — copy .mcp.json.example instead)
.mcp.json

# Website build outputs and Vercel config (machine-specific)
website/.vercel/
website/.next/
website/out/

# Process ID files
*.pid
.vercel
.env*.local
