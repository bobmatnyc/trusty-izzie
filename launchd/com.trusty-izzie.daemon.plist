<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.trusty-izzie.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/.local/bin/trusty-daemon</string>
        <string>start</string>
        <string>--foreground</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>WorkingDirectory</key>
    <string>__HOME__</string>

    <key>StandardOutPath</key>
    <string>__HOME__/.local/share/trusty-izzie/logs/daemon.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/.local/share/trusty-izzie/logs/daemon.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>__HOME__</string>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>TRUSTY_DATA_DIR</key>
        <string>__HOME__/.local/share/trusty-izzie</string>
    </dict>
</dict>
</plist>
